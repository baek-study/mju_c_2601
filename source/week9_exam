void do_mission2() 
{
	int choice;
	int my_potion = 0;
	
	while(1) 
    {
		printf("\n=== 마법 상점(인벤토리) ===\n");
		printf("1. 체력 포션 구매\n");
		printf("2. 마나 포션 구매\n");
		printf("3. 내 가방 확인하기\n");
		printf("0. 상점 나가기\n");
		printf("메뉴를 선택하세요: ");
		scanf("%d", &choice);
		
		if(choice == 1 || choice == 2) 
        {
			if(my_potion >= 9) 
            {
				printf("[구매 불가] 가방이 꽉 찼습니다!\n");
			} 
            else 
            {
				printf("[구매 완료] 포션을 구매했습니다.\n");
				my_potion++;
			}
		} 
        else if(choice == 3) 
        {
			int r, c;
			int count = 0;
			printf("\n--- 인벤토리 상태 ---\n");
			for(r = 0; r < 3; r++) 
            {
				for(c = 0; c < 3; c++) 
                {
					if(count < my_potion) 
                    {
						printf("♥ ");
					} 
                    else 
                    {
						printf("♡ ");
					}
					count++;
				}
				printf("\n");
			}
			printf("---------------------\n");
		} 
        else if(choice == 0) 
        {
			printf("상점을 나갑니다.\n");
			break;
		} 
        else 
        {
			printf("[오류] 잘못된 메뉴 번호.\n");
		}
	}
}