void exam1_nest_for()
{
	int i, j;
	
	for(i = 0; i < 5; i++) 
    {
	    for(j = 0; j < 5; j++) 
        {
			printf("hello world! ");
		}
		printf("\n");
	}
}

void exam2_nest_for()
{
	int x, y;
	
	for(x = 0; x < 5; x++) 
    {
	    for(y = 0; y < 10; y++) 
        {
			printf("*");
		}
		printf("\n");
	}
}

void exam3_nest_for()
{
	int dan, j;
	 
	for(dan = 2; dan <= 9; dan++) 
    {
		printf("--- %d단 ---\n", dan);
	    for(j = 1; j <= 9; j++) 
        {
			printf("%d * %d = %d\n", dan, j, dan * j);
		}
		printf("\n");
	}
} 

void exam4_while()
{ 
	int i = 0;
	 
	while(i < 5) 
    {
		printf("hello world!\n");
		i++;
	}
}

void exam5_while()
{
	int dan, i;
	
	printf("구구단 중에서 출력하고 싶은 단을 입력하시오: ");
	scanf("%d", &dan);
	
	i = 1;
	while(i <= 9) 
    {
		printf("%d * %d = %d\n", dan, i, dan * i);
		i++;
	}
}

void exam6_while()
{
	int i, n, sum;
	
	printf("정수를 입력하시오: ");
	scanf("%d", &n);
	
	i = 0;
	sum = 0;
	
	while(i <= n) 
    {
		if(i % 2 != 0) 
        {
			sum += i;
		}
		i++;
	}
	
	printf("0부터 %d까지 홀수의 합: %d\n", n, sum);
}

void exam7_while_menu()
{
	int num;
	int count = 0;
		
	while(1) 
    {
		printf("숫자를 입력(0은 종료): ");
		scanf("%d", &num);
		
		if (num == 0) 
        {
			printf("종료합니다. 총 %d번 입력했습니다.\n", count);
			break;
		}
		count++;
	}
}

void exam8_while_menu()
{
	int menu;
		
	while(1) 
    {
		printf("\n[메인 메뉴]");
	    printf("\n1. 음식 주문");
	    printf("\n2. 음식 계산");
	    printf("\n3. 종료");
		printf("\n메뉴를 입력: ");
	    scanf("%d", &menu);
	    
	    if (menu == 1) 
        {
			printf("음식을 주문합니다.\n");
		} 
        else if (menu == 2) 
        {
			printf("음식값을 계산합니다.\n");
		} 
        else if (menu == 3) 
        {
			printf("프로그램을 종료합니다.\n");
			break;
		} 
        else 
        {
			printf("잘못된 메뉴 번호입니다.\n");
		}
	}
}

