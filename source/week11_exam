void do_exam_math()
{
	double base, exp, powValue, number, sqrtValue;
	
	printf("밑과 지수를 입력하세요: ");
	scanf("%lf %lf", &base, &exp);
	powValue = pow(base, exp);
	printf("%.2lf의 %.2lf승은 %.2lf입니다.\n", base, exp, powValue);
	
	printf("제곱근을 구할 숫자를 입력하세요: ");
	scanf("%lf", &number);
	sqrtValue = sqrt(number);
	printf("%.2lf의 제곱근은 %.2lf입니다.\n", number, sqrtValue);
}

void do_mission()
{
	double rate = 0.05; 
	double final_balance = total_balance * pow(1 + rate, 5);
	
	printf("원금: %d원\n", total_balance);
	printf("5년 후 복리 계산된 최종 금액: %.2f원\n", final_balance);
}